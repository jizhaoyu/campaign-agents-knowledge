# Backend local environment example.
# Keep real secrets in your local shell or secret manager, not in git.

# Profiles:
# - default: H2 + local keyword retrieval.
# - ai-openai: OpenAI-compatible chat.
# - mysql: MySQL datasource + Flyway MySQL migrations.
SPRING_PROFILES_ACTIVE=ai-openai

# Docker Compose local ports and container MySQL credentials.
APP_PORT=8080
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=123456
MYSQL_APP_USER=agent_app
MYSQL_APP_PASSWORD=agent_app_password

# OpenAI-compatible chat.
# Map your local Codex config.toml values this way:
# model_provider base_url -> OPENAI_BASE_URL
# model -> OPENAI_CHAT_MODEL
OPENAI_API_KEY=replace-with-your-key
OPENAI_BASE_URL=https://mmw-codex.zenscaleai.com/v1
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_CHAT_COMPLETIONS_PATH=/chat/completions

# Embeddings are disabled by default because many relay providers expose chat only.
OPENAI_EMBEDDING_PROVIDER=none
OPENAI_EMBEDDING_ENABLED=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDINGS_PATH=/embeddings

# RAG refusal thresholds. Increase these in production to require stronger evidence.
APP_RAG_MIN_CITATION_COUNT=1
APP_RAG_MIN_TOP_SCORE=1.0

# MySQL. Use only after you intentionally created the business database.
# Running the app with the mysql profile will let Flyway create/update project tables.
MYSQL_JDBC_URL=jdbc:mysql://localhost:3306/agentdb?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=123456

# Document indexing worker pool.
APP_DOCUMENT_INDEX_CORE_POOL_SIZE=2
APP_DOCUMENT_INDEX_MAX_POOL_SIZE=4
APP_DOCUMENT_INDEX_QUEUE_CAPACITY=50
APP_DOCUMENT_INDEX_MAX_ATTEMPTS=3
APP_DOCUMENT_INDEX_BATCH_SIZE=5
APP_DOCUMENT_INDEX_POLL_DELAY_MS=5000
APP_DOCUMENT_INDEX_STALE_TIMEOUT_SECONDS=300

# Security.
APP_SECURITY_TOKEN_TTL_SECONDS=7200
APP_SECURITY_REFRESH_TOKEN_TTL_SECONDS=604800
APP_SECURITY_EXPIRED_TOKEN_CLEANUP_DELAY_MS=600000
APP_SECURITY_EXPIRED_TOKEN_CLEANUP_INITIAL_DELAY_MS=60000
APP_SECURITY_MAX_FAILED_LOGIN_ATTEMPTS=5
APP_SECURITY_LOGIN_LOCKOUT_MINUTES=15
